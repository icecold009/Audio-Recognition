SUPABASE_KEY=

# Rate limits
DAILY_LIMIT=15
MONTHLY_LIMIT=475

# Internal API secret (protects /api/match from direct access)
INTERNAL_API_SECRET=

# AudD (optional)
AUDD_API_TOKEN=

# AcoustID (optional)
ACOUSTID_API_KEY=

# Full path to fpcalc if not on PATH (optional)
FP_CALC_PATH=